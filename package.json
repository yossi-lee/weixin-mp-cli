{
  "name": "@yossi-lee/weixin-mp-cli",
  "version": "1.0.1",
  "description": "微信公众号 CLI 工具，支持从 Markdown 创建草稿、发布文章、管理素材",
  "type": "module",
  "main": "bin/wx.js",
  "bin": {
    "weixin-mp-cli": "./bin/wx.js"
  },
  "scripts": {
    "wx": "node bin/wx.js",
    "publish": "pnpm publish --access public --registry=https://registry.npmjs.org/ --no-git-checks"
  },
  "files": [
    "bin",
    "src"
  ],
  "keywords": [
    "wechat",
    "weixin",
    "公众号",
    "cli",
    "markdown"
  ],
  "author": "yossi-lee",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/yossi-lee/weixin-mp-cli.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "form-data": "^4.0.0",
    "inquirer": "^9.2.0",
    "marked": "^14.0.0"
  }
}
